<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SR160PowerConfig.MainWindow"
        Title="CHIPMO — SR160 Power Config"
        Width="520" Height="780"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="0">

        <!-- Header -->
        <Border Background="#212529" Padding="15,8,15,10">
            <StackPanel>
                <TextBlock Text="CHIPMO" FontSize="20" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Chainway SR160 UHF RFID — TX Power тохируулагч"
                           FontSize="12" Foreground="#ADB5BD" />
            </StackPanel>
        </Border>

        <StackPanel Margin="12,8,12,0" Spacing="8">

            <!-- Холболт -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Холболт" FontWeight="Bold" FontSize="13" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <RadioButton x:Name="rbUsb" Content="USB" GroupName="ConnType"
                                     IsChecked="True" Click="ConnType_Changed" />
                        <RadioButton x:Name="rbBluetooth" Content="Bluetooth (HID)" GroupName="ConnType"
                                     Click="ConnType_Changed" />
                    </StackPanel>

                    <!-- Bluetooth: pair-лсэн бол шууд ажиллана -->
                    <TextBlock x:Name="lblBtHint" IsVisible="False"
                               Text="SR160-аа macOS Bluetooth-ээр pair хийсэн бол EPC уншилт шууд ажиллана.&#x0a;Power тохируулахад USB шаардлагатай."
                               FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" />

                    <TextBlock x:Name="lblStatus" Text="● Салсан" Foreground="Red"
                               FontSize="13" FontWeight="Bold" />

                    <!-- USB: холбогдох товч -->
                    <StackPanel x:Name="pnlUsbButtons" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="btnConnect" Content="Холбогдох" Width="110"
                                Click="BtnConnect_Click" />
                        <Button x:Name="btnDisconnect" Content="Салгах" Width="90"
                                IsEnabled="False" Click="BtnDisconnect_Click" />
                    </StackPanel>

                    <TextBlock x:Name="lblDebug" Text="" FontSize="10"
                               Foreground="#888888" TextWrapping="Wrap"
                               FontFamily="Consolas,Menlo,monospace" />
                </StackPanel>
            </Border>

            <!-- Антенна #1 — USB only (Windows) -->
            <Border x:Name="pnlAntenna" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8"
                    IsEnabled="False" Opacity="0.5">
                <StackPanel Spacing="4">
                    <TextBlock Text="Антенна #1 (USB — Windows)" FontWeight="Bold" FontSize="13" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="lblCurrentPower" Text="Одоогийн хүч:  —"
                                   FontSize="14" VerticalAlignment="Center" />
                        <Button x:Name="btnRefresh" Content="Шинэчлэх" Grid.Column="1"
                                Width="90" Click="BtnRefresh_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Хүч тохируулах — USB only (Windows) -->
            <Border x:Name="pnlPower" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8"
                    IsEnabled="False" Opacity="0.5">
                <StackPanel Spacing="6">
                    <TextBlock Text="Хүч тохируулах (5 – 30 dBm) (USB — Windows)" FontWeight="Bold" FontSize="13" />

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="5" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <Slider x:Name="trackPower" Grid.Column="1"
                                Minimum="5" Maximum="30" Value="20"
                                IsSnapToTickEnabled="True" TickFrequency="1" />
                        <TextBlock Text="30" Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </Grid>

                    <TextBlock x:Name="lblPowerValue" Text="— dBm"
                               FontSize="20" FontWeight="Bold" Foreground="#1565C0"
                               HorizontalAlignment="Center" />

                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <NumericUpDown x:Name="numPower" Minimum="5" Maximum="30" Value="20"
                                       Width="90" FormatString="0" Increment="1" />
                        <TextBlock Text="dBm" Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0" />
                        <Button x:Name="btnSave" Content="Хадгалах" Grid.Column="3"
                                Width="120" Height="36" FontWeight="Bold" FontSize="14"
                                Background="#4CAF50" Foreground="White"
                                Click="BtnSave_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- EPC уншигч — USB + Bluetooth аль алинд -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="EPC уншигч" FontWeight="Bold" FontSize="13" />

                    <!-- Reading mode -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton x:Name="rbSingle" Content="Single (гох = 1 таг)"
                                     GroupName="ReadMode" IsChecked="True"
                                     Click="ReadMode_Changed" />
                        <RadioButton x:Name="rbContinuous" Content="Continuous (гох = олон таг)"
                                     GroupName="ReadMode"
                                     Click="ReadMode_Changed" />
                    </StackPanel>

                    <TextBlock x:Name="lblReadStatus" Text="" FontSize="11"
                               FontWeight="Bold" />

                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2,0,0">
                        <TextBlock Text="EPC:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="txtEpcInput" Grid.Column="1"
                                 FontFamily="Consolas,Menlo,monospace" FontSize="13"
                                 Watermark="SR160 энд шивнэ..."
                                 KeyDown="TxtEpcInput_KeyDown"
                                 TextChanged="TxtEpcInput_TextChanged" />
                        <Button x:Name="btnClearList" Content="Цэвэрлэх" Grid.Column="2"
                                Width="90" Margin="8,0,0,0" Click="BtnClearList_Click" />
                    </Grid>

                    <TextBlock x:Name="lblTagCount" Text="Нийт: 0 таг"
                               FontSize="13" FontWeight="Bold" />

                    <DataGrid x:Name="dgTags" Height="160"
                              IsReadOnly="True" CanUserResizeColumns="True"
                              GridLinesVisibility="All"
                              FontFamily="Consolas,Menlo,monospace" FontSize="12"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50" />
                            <DataGridTextColumn Header="EPC код" Binding="{Binding Epc}" Width="*" />
                            <DataGridTextColumn Header="Тоо" Binding="{Binding Count}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </StackPanel>
</Window>
