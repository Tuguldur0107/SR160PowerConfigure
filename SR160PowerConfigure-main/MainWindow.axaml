<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SR160PowerConfig.MainWindow"
        x:CompileBindings="False"
        Title="CHIPMO SR160 Power Config"
        Width="520" Height="780"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="0">

        <!-- Header -->
        <Border Background="#212529" Padding="15,8,15,10">
            <StackPanel>
                <TextBlock Text="CHIPMO" FontSize="20" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Chainway SR160 UHF RFID TX Power Config"
                           FontSize="12" Foreground="#ADB5BD" />
            </StackPanel>
        </Border>

        <StackPanel Margin="12,8,12,0" Spacing="8">

            <!-- Connection -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Connection" FontWeight="Bold" FontSize="13" />

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <RadioButton x:Name="rbUsb" Content="USB" GroupName="ConnType"
                                     IsChecked="True" Click="ConnType_Changed" />
                        <RadioButton x:Name="rbBluetooth" Content="Bluetooth (HID)" GroupName="ConnType"
                                     Click="ConnType_Changed" />
                    </StackPanel>

                    <TextBlock x:Name="lblBtHint" IsVisible="False"
                               Text="If the SR160 is paired as Bluetooth HID, EPC input can work here.&#x0a;Use USB for power configuration."
                               FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" />

                    <TextBlock x:Name="lblStatus" Text="Disconnected" Foreground="Red"
                               FontSize="13" FontWeight="Bold" />

                    <StackPanel x:Name="pnlUsbButtons" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="btnConnect" Content="Connect" Width="110"
                                Click="BtnConnect_Click" />
                        <Button x:Name="btnDisconnect" Content="Disconnect" Width="90"
                                IsEnabled="False" Click="BtnDisconnect_Click" />
                    </StackPanel>

                    <TextBlock x:Name="lblDebug" Text="" FontSize="10"
                               Foreground="#888888" TextWrapping="Wrap"
                               FontFamily="Consolas,Menlo,monospace" />
                </StackPanel>
            </Border>

            <!-- Antenna power -->
            <Border x:Name="pnlAntenna" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8"
                    IsEnabled="False" Opacity="0.5">
                <StackPanel Spacing="4">
                    <TextBlock Text="Antenna #1 (USB only)" FontWeight="Bold" FontSize="13" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="lblCurrentPower" Text="Current power: --"
                                   FontSize="14" VerticalAlignment="Center" />
                        <Button x:Name="btnRefresh" Content="Refresh" Grid.Column="1"
                                Width="90" Click="BtnRefresh_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Power setting -->
            <Border x:Name="pnlPower" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8"
                    IsEnabled="False" Opacity="0.5">
                <StackPanel Spacing="6">
                    <TextBlock Text="Power setting (5 to 30 dBm, USB only)" FontWeight="Bold" FontSize="13" />

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Text="5" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <Slider x:Name="trackPower" Grid.Column="1"
                                Minimum="5" Maximum="30" Value="20"
                                IsSnapToTickEnabled="True" TickFrequency="1" />
                        <TextBlock Text="30" Grid.Column="2" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </Grid>

                    <TextBlock x:Name="lblPowerValue" Text="-- dBm"
                               FontSize="20" FontWeight="Bold" Foreground="#1565C0"
                               HorizontalAlignment="Center" />

                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <NumericUpDown x:Name="numPower" Minimum="5" Maximum="30" Value="20"
                                       Width="90" FormatString="0" Increment="1" />
                        <TextBlock Text="dBm" Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0" />
                        <Button x:Name="btnSave" Content="Save" Grid.Column="3"
                                Width="120" Height="36" FontWeight="Bold" FontSize="14"
                                Background="#4CAF50" Foreground="White"
                                Click="BtnSave_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- EPC input -->
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="EPC Reading" FontWeight="Bold" FontSize="13" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <RadioButton x:Name="rbSingle" Content="Single"
                                     GroupName="ReadMode" IsChecked="True"
                                     Click="ReadMode_Changed" />
                        <RadioButton x:Name="rbContinuous" Content="Continuous"
                                     GroupName="ReadMode"
                                     Click="ReadMode_Changed" />
                    </StackPanel>

                    <TextBlock x:Name="lblReadStatus" Text="" FontSize="11"
                               FontWeight="Bold" />

                    <CheckBox x:Name="chkSendToActiveApp"
                              IsChecked="True" IsVisible="False"
                              Click="ExternalOutput_Changed" />
                    <TextBlock Text="Open Notepad or another typing program before reading to send EPC there."
                               FontSize="11" Foreground="#666666"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="lblTriggerDebug"
                               Text="Scanner trigger disabled"
                               FontSize="10" Foreground="#888888"
                               TextWrapping="Wrap" />

                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,2,0,0">
                        <TextBlock Text="EPC:" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox x:Name="txtEpcInput" Grid.Column="1"
                                 FontFamily="Consolas,Menlo,monospace" FontSize="13"
                                 PlaceholderText="Scan with SR160..."
                                 KeyDown="TxtEpcInput_KeyDown"
                                 TextChanged="TxtEpcInput_TextChanged" />
                        <Button x:Name="btnStartRead" Content="Start" Grid.Column="2"
                                Width="70" Margin="8,0,0,0" Click="BtnStartRead_Click" />
                        <Button x:Name="btnClearList" Content="Clear" Grid.Column="3"
                                Width="90" Margin="8,0,0,0" Click="BtnClearList_Click" />
                    </Grid>

                    <TextBlock x:Name="lblTagCount" Text="Total: 0 unique tag"
                               FontSize="13" FontWeight="Bold" />

                    <DataGrid x:Name="dgTags" Height="160"
                              IsReadOnly="True" CanUserResizeColumns="True"
                              GridLinesVisibility="All"
                              FontFamily="Consolas,Menlo,monospace" FontSize="12"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50" />
                            <DataGridTextColumn Header="EPC Code" Binding="{Binding Epc}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </StackPanel>
</Window>
